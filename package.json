{
  "name": "wrenlist-clean",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src --max-warnings 0",
    "format": "prettier --write src",
    "type-check": "tsc --noEmit",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "test:supabase": "ts-node scripts/test-supabase-connection.ts",
    "test:ebay-crypto": "tsx scripts/test-ebay-token-crypto.ts",
    "test:version-compare": "tsx scripts/test-version-compare.ts",
    "clean": "npm run format && npm run lint && npm run type-check",
    "build:extension": "rm -rf extension/dist && tsc -p extension/tsconfig.json",
    "watch:extension": "rm -rf extension/dist && tsc -p extension/tsconfig.json --watch --preserveWatchOutput"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@sentry/nextjs": "^10.47.0",
    "@stripe/stripe-js": "^9.0.0",
    "@supabase/auth-helpers-nextjs": "^0.10.0",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.100.1",
    "@types/qrcode": "^1.5.6",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "barcode-detector": "^3.1.2",
    "html5-qrcode": "^2.3.8",
    "lucide-react": "^1.7.0",
    "next": "^15.0.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.10.0",
    "sonner": "^1.3.0",
    "stripe": "^21.0.1",
    "undici": "^7.24.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/chrome": "^0.0.269",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.55.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.0",
    "prettier": "^3.1.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0"
  }
}
