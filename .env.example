# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL="https://[project-id].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[anon-key-or-publishable-key]"

# Marketplace APIs
EBAY_CLIENT_ID="[your-ebay-client-id]"
EBAY_CLIENT_SECRET="[your-ebay-client-secret]"
EBAY_DEV_ID="[your-ebay-dev-id]"
EBAY_AUTH_BASE_URL="https://auth.ebay.com"
EBAY_BASE_URL="https://api.ebay.com"

# Anthropic API (for AI features)
ANTHROPIC_API_KEY="[your-anthropic-api-key]"

# Stripe Configuration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="[your-stripe-publishable-key]"
STRIPE_SECRET_KEY="[your-stripe-secret-key]"
STRIPE_PRICE_NESTER_MONTHLY="[price-id]"
STRIPE_PRICE_NESTER_ANNUAL="[price-id]"
STRIPE_PRICE_FORAGER_MONTHLY="[price-id]"
STRIPE_PRICE_FORAGER_ANNUAL="[price-id]"
STRIPE_PRICE_FLOCK_MONTHLY="[price-id]"
STRIPE_PRICE_FLOCK_ANNUAL="[price-id]"

# Vercel Configuration (auto-set in production)
NEXT_PUBLIC_VERCEL_URL="localhost:3000"
